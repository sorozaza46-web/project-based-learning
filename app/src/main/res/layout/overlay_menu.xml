<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="#222222"
    android:orientation="vertical"
    android:padding="12dp"
    android:elevation="10dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEALTH MEMORY MENU"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp" />
        <Button
            android:id="@+id/btnCloseMenu"
            android:layout_width="40dp"
            android:layout_height="35dp"
            android:text="X"
            android:backgroundTint="#FF3333"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <Spinner
        android:id="@+id/spnOverlayApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/edtOverlaySearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Aranacak Değer"
        android:textColorHint="#AAAAAA"
        android:textColor="#FFFFFF"
        android:inputType="numberSigned" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="5dp">
        <Button
            android:id="@+id/btnFirstScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="İlk Taram"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btnNextScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filtrele"
            android:textSize="12sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#444444"
        android:layout_marginVertical="10dp"/>

    <EditText
        android:id="@+id/edtOverlayNewValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Yeni Değer"
        android:textColorHint="#AAAAAA"
        android:textColor="#FFFFFF"
        android:inputType="numberSigned" />

    <Button
        android:id="@+id/btnOverlayWrite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEĞERLERİ DEĞİŞTİR"
        android:backgroundTint="#00AA00"
        android:layout_marginTop="5dp" />
</LinearLayout>

