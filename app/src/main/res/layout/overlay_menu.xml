<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="320dp"
    android:layout_height="wrap_content"
    android:background="#222222"
    android:orientation="vertical"
    android:padding="14dp"
    android:elevation="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="STEALTH MEMORY ENGINE"
            android:textColor="#00FF00"
            android:textStyle="bold"
            android:textSize="14sp" />
        <Button
            android:id="@+id/btnCloseMenu"
            android:layout_width="45dp"
            android:layout_height="38dp"
            android:text="X"
            android:backgroundTint="#FF3333"
            android:layout_alignParentEnd="true" />
    </RelativeLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hedef Süreç / Uygulama:"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>
        
    <Spinner
        android:id="@+id/spnOverlayApps"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/edtOverlayManualPackage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Manuel Paket Adı (Örn: com.tencent.ig)"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:backgroundTint="#00FF00"
        android:textSize="13sp"
        android:inputType="textNoSuggestions"
        android:layout_marginBottom="12dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#444444"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bellek Tarama ve Filtreleme:"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:layout_marginBottom="4dp"/>

    <EditText
        android:id="@+id/edtOverlaySearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Aranacak Sayısal Değer"
        android:textColorHint="#AAAAAA"
        android:textColor="#FFFFFF"
        android:inputType="numberSigned"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginTop="6dp">
        <Button
            android:id="@+id/btnFirstScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="İlk Tarama"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btnNextScan"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Filtrele"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:textSize="12sp"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#444444"
        android:layout_marginVertical="12dp"/>

    <EditText
        android:id="@+id/edtOverlayNewValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Yazılacak Yeni Değer"
        android:textColorHint="#AAAAAA"
        android:textColor="#FFFFFF"
        android:inputType="numberSigned"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnOverlayWrite"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="DEĞERLERİ DEĞİŞTİR"
        android:backgroundTint="#00AA00"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />
</LinearLayout>
